{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build HalEventWeek (msbuild)",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\HalEventWeek.sln",
                "/t:Rebuild",
                "/p:Configuration=Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "ソリューション全体をビルドし、未解決外部参照を回避します。"
        },
        {
            "label": "C/C++: cl.exe シングルファイルビルド",
            "type": "cppbuild",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "none",
            "detail": "個別のソースファイル向け（依存ファイルがリンクされない場合があります）。"
        }
    ]
}